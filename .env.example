# ── LLM Configuration ─────────────────────────────────────────────────────
# Ollama runs locally. Default URL and model shown below.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# OpenAI fallback — only used if Ollama is not reachable
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-3.5-turbo
